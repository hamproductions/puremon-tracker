# Base path the app is served from (use "/" for root, "/puremon-tracker/" for GitHub Pages subpath)
PUBLIC_ENV__BASE_URL=/

# Supabase (optional). Leave blank to run fully local-first (localStorage only).
# When set, enables Twitter/X login, cloud image storage and crowdsource approval.
PUBLIC_ENV__SUPABASE_URL=
PUBLIC_ENV__SUPABASE_ANON_KEY=

# Comma-separated X(Twitter) handles granted admin in the UI (no @). e.g. myhandle,otherhandle
PUBLIC_ENV__ADMIN_HANDLES=

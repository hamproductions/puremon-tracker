{
  "name": "puremon-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vike build",
    "ci:build": "NODE_ENV=production vike build",
    "type-check": "tsc",
    "check": "bun lint && bun type-check",
    "format": "prettier --write ./src",
    "lint": "oxlint src && eslint src --concurrency=auto",
    "lint:fix": "oxlint src --fix && eslint src --fix --concurrency=auto",
    "fix": "bun lint:fix",
    "preview": "vite preview",
    "prepare": "panda codegen",
    "codegen:components": "bunx @park-ui/cli components add --all"
  },
  "dependencies": {
    "@ark-ui/react": "^4.8.1",
    "@pandacss/dev": "^1.7.1",
    "@park-ui/panda-preset": "^0.43.1",
    "@supabase/supabase-js": "^2.45.0",
    "file-saver": "^2.0.5",
    "lodash-es": "^4.17.21",
    "lz-string": "^1.5.0",
    "modern-screenshot": "^4.5.5",
    "path-browserify": "^1.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^6.0.2",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.4.0",
    "vike": "^0.4.249",
    "vike-react": "^0.5.11",
    "vite-plugin-cjs-interop": "^2.1.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@pandabox/prettier-plugin": "^0.1.3",
    "@pandacss/eslint-plugin": "^0.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^19.0.0-beta-decd7b8-20250118",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-oxlint": "^1.25.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react-compiler": "^19.0.0-beta-decd7b8-20250118",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^14.0.0",
    "oxlint": "^1.25.0",
    "postcss-prune-var": "^1.1.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.2"
  }
}
